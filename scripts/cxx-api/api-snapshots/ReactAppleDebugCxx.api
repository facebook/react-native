template <typename ClassT, typename ReturnT, typename... ArgsT>
struct facebook::react::bridging::detail::function_wrapper<ReturnT(ClassT::*)(ArgsT...) const> {
  public using type = std::function<ReturnT(ArgsT...)>;
}

template <typename ClassT, typename ReturnT, typename... ArgsT>
struct facebook::react::bridging::detail::function_wrapper<ReturnT(ClassT::*)(ArgsT...)> {
  public using type = std::function<ReturnT(ArgsT...)>;
}

